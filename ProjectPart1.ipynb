   "source": [
    "# Task 0 part 1\n",
    "import pandas as pd\n",
    "\n",
    "# Load the raw dictionary\n",
    "raw_dict = pd.read_pickle(\"delta_a100_gpu_xid_dataset.pkl\") #equivalent to opening file using \"rb\" and using the \"pickle.load\" function"
   ]
